<%- include("partials/header", { pageTitle, activePage }) %>

<main>
  <section class="team-hero page-band">
    <div class="container">
      <div class="team-title reveal">
        <p class="eyebrow">Elite profile lineup</p>
        <h1>OUR TEAM</h1>
        <p>Choose a member to reveal their bio, skills, languages, projects, achievements, and contact links.</p>
      </div>

      <div class="team-showcase" id="teamShowcase">
        <div class="angled-card-grid" aria-label="Team member cards">
          <% members.forEach((member) => { %>
            <button class="team-card" type="button" data-member-id="<%= member.id %>" aria-label="View <%= member.name %> profile" aria-pressed="false">
              <span class="card-number">0<%= member.id %></span>
              <span class="image-frame">
                <img src="<%= member.image %>" alt="<%= member.name %> profile placeholder">
              </span>
              <span class="member-nameplate">
                <strong><%= member.name %></strong>
                <small><%= member.role %></small>
              </span>
              <span class="member-tagline"><%= member.tagline %></span>
            </button>
          <% }) %>
        </div>

        <section class="member-detail-panel" id="memberDetailPanel" aria-live="polite" aria-hidden="true"></section>
      </div>
    </div>
  </section>
</main>

<script id="members-data" type="application/json"><%- JSON.stringify(members).replace(/</g, "\\u003c") %></script>

<%- include("partials/footer") %>
