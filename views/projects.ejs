<%- include("partials/header", { pageTitle, activePage }) %>

<main>
  <section class="page-hero section">
    <div class="container narrow-heading reveal">
      <p class="eyebrow">Project archive</p>
      <h1>Projects</h1>
      <p>Team builds and individual contributions presented in a clean orange-black card system.</p>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <div class="project-grid">
        <% projects.forEach((project, index) => { %>
          <article class="project-card reveal">
            <div class="project-index">0<%= index + 1 %></div>
            <span class="project-owner"><%= project.owner %></span>
            <h2><%= project.title %></h2>
            <p><%= project.description %></p>
            <div class="project-meta">
              <span><%= project.category %></span>
            </div>
            <div class="badge-list">
              <% project.technologies.forEach((technology) => { %>
                <span><%= technology %></span>
              <% }) %>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
