<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Increment Counter</title>

  <style>
    body {
      margin: 0;
      height: 100vh;
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #ff8c00, #111111);
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .counter-card {
      background: white;
      padding: 40px;
      width: 320px;
      text-align: center;
      border-radius: 20px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
    }

    .counter-card h1 {
      margin-bottom: 20px;
      color: #111111;
    }

    #counter {
      font-size: 60px;
      font-weight: bold;
      color: #ff8c00;
      margin: 20px 0;
    }

    button {
      border: none;
      padding: 12px 20px;
      margin: 5px;
      border-radius: 10px;
      cursor: pointer;
      font-size: 16px;
      font-weight: bold;
      transition: 0.3s;
    }

    .increment {
      background: #ff8c00;
      color: white;
    }

    .decrement {
      background: #111111;
      color: white;
    }

    .reset {
      background: #e0e0e0;
      color: #111111;
    }

    button:hover {
      transform: scale(1.08);
      opacity: 0.9;
    }
  </style>
</head>
<body>

  <div class="counter-card">
    <h1>Counter</h1>

    <div id="counter">0</div>

    <button class="decrement" onclick="decrement()">-</button>
    <button class="increment" onclick="increment()">+</button>
    <button class="reset" onclick="resetCounter()">Reset</button>
  </div>

  <script>
    let count = 0;

    function increment() {
      count++;
      document.getElementById("counter").textContent = count;
    }

    function decrement() {
      count--;
      document.getElementById("counter").textContent = count;
    }

    function resetCounter() {
      count = 0;
      document.getElementById("counter").textContent = count;
    }
  </script>

</body>
</html>